# ══════════════════════════════════════════
# CONFIGURACIÓN DEL WEBHOOK
# ══════════════════════════════════════════

# ─── Google Sheets ───
# Paso 1: Ve a https://console.cloud.google.com
# Paso 2: Crea proyecto → Habilita Google Sheets API y Google Drive API
# Paso 3: Crea Service Account → Descarga el JSON como credentials.json
# Paso 4: Comparte tu Google Sheet con el email de la Service Account
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEET_ID=PEGA_AQUI_EL_ID_DE_TU_SHEET

# ─── Email SMTP (Gmail) ───
# Paso 1: Ve a https://myaccount.google.com/apppasswords
# Paso 2: Genera una contraseña de aplicación
# Paso 3: Pégala aquí abajo
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=tu-email@gmail.com
EMAIL_NOTIFY_TO=donde-quieres-recibir@gmail.com

# ─── URL pública del servidor ───
# Necesario para que los links de imágenes en el email funcionen correctamente
# Ejemplo: https://webhook.tudominio.com
BASE_URL=https://tu-dominio.com
